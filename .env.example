# Copy this file to .env and fill in your values
# cp .env.example .env

# Generate a random secret key:  python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-long-random-string

# MongoDB Atlas free-tier connection string
# 1. Go to https://cloud.mongodb.com → free cluster → Connect → Drivers
# 2. Copy the connection string and replace <user>, <password>, <cluster>
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/vmmanager?retryWrites=true&w=majority&appName=vmmanager

# Database name (must match the one in the Atlas URI)
DB_NAME=vmmanager
